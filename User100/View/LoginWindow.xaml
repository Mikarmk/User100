<Window x:Class="User100.View.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:User100.View"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        MaxHeight="460" MinHeight="440"
        MaxWidth="900" MinWidth="700"
        >
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="200">
            <TextBlock Text="Логин"/>
            <TextBox x:Name="LoginBox"
                     Margin="0 4 0 0"/>
            <TextBlock Text="Пароль"
                       Margin="0 8 0 0"/>
            <PasswordBox x:Name="PasswordBox"
                         Margin="0 4 0 0"/>
            <Button x:Name="Btn_login"
                    Content="Войти" Click="Btn_login_Click"
                    Margin="0 16 0 0"
                    />
            <Button x:Name="Btn_go"
                    Content="Посмотреть товары"
                    Margin="0 8 0 0" Click="Btn_go_Click"/>

        </StackPanel>
    </Grid>
</Window>
