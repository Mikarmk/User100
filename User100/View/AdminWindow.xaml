<Window x:Class="User100.View.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:User100.View"
        mc:Ignorable="d"
        Title="Окно администратора"
        Height="500" Width="1000"
        WindowStartupLocation="CenterScreen"
        MaxHeight="600" MinHeight="400"
        MinWidth="900" MaxWidth="1100">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Grid.Column="0" Grid.Row="0"
                    Grid.ColumnSpan="6" Grid.RowSpan="1"
                    Margin="10">

            <Image Source="/Media/Icon.JPG" Height="57" Width="69"/>
            <TextBlock Text="Окно администратора" Margin="20" FontSize="16"/>


            <TextBox x:Name="SearchBox" Width="200" Margin="10"/>
            <Button x:Name="Search_btn" Content="Найти" Margin="10 10 100 10 " Width="100" Click="Search_btn_Click"/>

        </StackPanel>
        <Button x:Name="Exit_btn" Content="Выход" Width="100" Margin="20" Grid.Column="5" Click="Exit_btn_Click"/>


        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Grid.Column="0" Grid.Row="1"
                    Grid.ColumnSpan="6" Grid.RowSpan="1"
                    Margin="10">

            <Button x:Name="Add_btn" Content="Добавить" Width="100" Margin="10" ButtonBase.Click="Add_btn_Click"/>
            <Button x:Name="Edit_btn" Content="Редактировать" Width="100" Margin="10" Click="Edit_btn_Click"/>
            <Button x:Name="Delete_btn" Content="Удалить" Width="100" Margin="10" Click="Delete_btn_Click"/>

        </StackPanel>


        <DataGrid x:Name="DG_Tovar"
                  CanUserAddRows="False"
                  CanUserSortColumns="True"
                  AutoGenerateColumns="False"
                  Grid.Column="0" Grid.Row="2"
                    Grid.ColumnSpan="6" Grid.RowSpan="4">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Articul}" Width="100"/>
                <DataGridTextColumn Header="Название" Binding="{Binding TovarName}" Width="120"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Cena}" Width="80"/>
                <DataGridTextColumn Header="Скидка" Binding="{Binding Skidka}" Width="70"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Kolichestvo}" Width="90"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Opisanye}" Width="200"/>
            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</Window>